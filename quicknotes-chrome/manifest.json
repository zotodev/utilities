{
  "manifest_version": 3,
  "name": "QuickNotes",
  "version": "1.0.0",
  "description": "Store and manage your notes locally using localStorage or IndexedDB. Fast, private, and offline-ready.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "QuickNotes",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "permissions": ["storage"],
  "host_permissions": []
}
